{
  "Sitemap": {
    "BaseUrl": "https://www.example.com", // goood example you want to check
    "SitemapPath": "/sitemap",
    "Concurrency": 16,
    "RequestTimeoutSeconds": 20,
    "UserAgent": "SitemapChecker/1.0 (+https://yourdomain.example)",
    "ErrorOutputFile": "sitemap-errors.csv",
    "ComparisonBaseUrl": "https://localhost", // for example the local enviroment
    "ComparisonErrorOutputFile": "html-comparison-results.csv",
    "MaxRetries": 3,
    "MinSimilarityThreshold": 95.0,
    "RetryDelayMs": 1000
  }
}
